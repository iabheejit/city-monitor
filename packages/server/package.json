{
  "name": "@city-monitor/server",
  "version": "0.0.1",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "node --env-file=.env ../../node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node ../../node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node --env-file=.env ../../node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file=.env ../../node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@city-monitor/shared": "*",
    "@langchain/openai": "^1.2.11",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.39",
    "express": "^5",
    "express-rate-limit": "^8.2.2",
    "fast-xml-parser": "^5.4.1",
    "helmet": "^8.1.0",
    "node-cron": "^3.0.3",
    "postgres": "^3.4",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.30",
    "tsx": "^4",
    "vitest": "^3"
  }
}
